# NovelCraft Environment

# PostgreSQL
POSTGRES_USER=novelcraft
POSTGRES_PASSWORD=novelcraft_dev
POSTGRES_DB=novelcraft
DATABASE_URL=postgresql+asyncpg://novelcraft:novelcraft_dev@db:5432/novelcraft

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM (user-configured per-account, defaults here)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=

# Redis
REDIS_URL=redis://redis:6379/0
