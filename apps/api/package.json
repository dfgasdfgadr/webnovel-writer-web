{
  "name": "@novelcraft/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "setup": "pip install -r requirements.txt",
    "seed": "python -m scripts.seed_dev_user",
    "test": "python -m pytest tests/ -v",
    "test:coverage": "python -m pytest tests/ -v --cov=app --cov-report=term-missing"
  }
}
