# NovelCraft API — 环境变量配置
#
# 配置优先级（LLM 调用时）：
#   1. 用户级 LLM 设置（Web UI → 设置页）— 最高优先级
#   2. 此 .env 文件 — 全局 fallback
#
# 用户可通过 /settings 页面的「测试连接」按钮验证 API 可用性。
# 未配置时，写作台顶部会显示引导提示。

# --- LLM 配置（全局 fallback）---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 数据库 ---
# 不设置时默认使用 SQLite（apps/api/novelcraft.db）
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/novelcraft

# --- JWT ---
JWT_SECRET=change-me-in-production

# --- 加密密钥（用于加密存储用户 API Key）---
# 建议设置固定值（≥16 字符），避免重启后 jwt_secret 变化导致已保存的 API Key 无法解密。
# 修改此值后，所有已保存的用户 API Key 需要重新保存。
# ENCRYPT_KEY=your-fixed-secret-at-least-16-chars

# --- CORS ---
# 可选，默认 http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
