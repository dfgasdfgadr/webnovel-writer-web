{
  "name": "novelcraft",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @novelcraft/web dev",
    "dev:api": "pnpm --filter @novelcraft/api dev",
    "setup:api": "pnpm --filter @novelcraft/api setup",
    "seed": "pnpm --filter @novelcraft/api seed",
    "build:web": "pnpm --filter @novelcraft/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter @novelcraft/api test",
    "test:web": "pnpm --filter @novelcraft/web test",
    "test:coverage": "pnpm --filter @novelcraft/api test:coverage && pnpm --filter @novelcraft/web test:coverage"
  },
  "devDependencies": {
    "shadcn": "^4.8.0"
  }
}
